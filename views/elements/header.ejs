<header>
  <nav class="flex-row-wrap">
    <h2>FileSpace</h2>
    <ul class="flex-row-wrap nav-ul">
      <% if (isAuthenticated) { %>
        <li>
          <a href="/files/">My Files</a>
        </li>
        <li>
          <form method="POST" action="/logout">
            <button type="Submit">Log Out</button>
          </form>
        </li>
        <% } else { %>
          <li>
            <a href="/">Homepage</a>
          </li>
      <li>
        <a href="/login">Log In</a>
      </li>
